// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
}

model Batch {
  id            String   @id @default(cuid())
  name          String
  entryDate     DateTime
  animalCount   Int
  birthWeeks    Int
  initialWeight Float    // kg per animal
  costPerAnimal Float    // currency
  status        BatchStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  weightRecords       WeightRecord[]
  feedRecords         FeedRecord[]
  expenses            Expense[]
  vaccinationSchedules VaccinationSchedule[]
}

model WeightRecord {
  id          String   @id @default(cuid())
  batchId     String
  recordDate  DateTime
  weekNumber  Int
  totalWeight Float    // kg (total for the batch)
  animalCount Int      // animals weighed (some may have been sold/died)
  notes       String?
  createdAt   DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, weekNumber])
}

model FeedRecord {
  id          String   @id @default(cuid())
  batchId     String
  date        DateTime
  feedType    String
  quantityKg  Float
  costPerKg   Float
  notes       String?
  createdAt   DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String          @id @default(cuid())
  batchId     String
  date        DateTime
  category    ExpenseCategory
  description String
  amount      Float
  notes       String?
  createdAt   DateTime        @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model VaccinationSchedule {
  id            String       @id @default(cuid())
  batchId       String
  scheduledDate DateTime
  type          ScheduleType
  product       String
  completed     Boolean      @default(false)
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime     @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

enum BatchStatus {
  ACTIVE
  SOLD
  CLOSED
}

enum ExpenseCategory {
  VACCINE
  DEWORMER
  VITAMIN
  OTHER
}

enum ScheduleType {
  VACCINE
  DEWORMER
}
